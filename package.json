{
  "name": "workit",
  "version": "0.1.0",
  "description": "CLI workflow manager for multi-project git worktrees",
  "type": "module",
  "bin": {
    "workit": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build:npm": "bun build src/cli.ts --target=node --outfile=dist/cli.js && sed -i '' 's|#!/usr/bin/env bun|#!/usr/bin/env node|' dist/cli.js",
    "build:binary": "bun build src/cli.ts --compile --outfile=dist/workit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
